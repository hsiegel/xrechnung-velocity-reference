#macro(xrText $tag $value)
#if($xml.has($value))
<$tag>$xml.text($value)</$tag>
#end
#end

#macro(xrDate $tag $value)
#if($xml.has($value))
<$tag>$xml.date($value)</$tag>
#end
#end

#macro(xrNumber $tag $value)
#if($xml.has($value))
<$tag>$xml.number($value)</$tag>
#end
#end

#macro(xrAmount $tag $value $currency)
#if($xml.has($value))
<$tag#if($xml.has($currency)) currencyID="$xml.attr($currency)"#end>$xml.amount($value)</$tag>
#end
#end

#macro(xrQuantity $tag $value $unitCode)
#if($xml.has($value))
<$tag#if($xml.has($unitCode)) unitCode="$xml.attr($unitCode)"#end>$xml.number($value)</$tag>
#end
#end

#macro(xrIdentifier $tag $value $schemeId)
#if($xml.has($value))
<$tag#if($xml.has($schemeId)) schemeID="$xml.attr($schemeId)"#end>$xml.text($value)</$tag>
#end
#end

#macro(xrNote $tag $note)
#set($xrNoteText = $note.text)
#set($xrSubjectCode = $note.subjectCode)
#if($xml.has($xrNoteText))
  #if($xml.has($xrSubjectCode))
    #set($xrHash = '#')
<$tag>$xrHash$xml.text($xrSubjectCode)$xrHash$xml.text($xrNoteText)</$tag>
  #else
<$tag>$xml.text($xrNoteText)</$tag>
  #end
#end
#end

#macro(xrProjectReference $projectReferenceId)
#if($xml.has($projectReferenceId))
<cac:ProjectReference>
  #xrText("cbc:ID" $projectReferenceId)
</cac:ProjectReference>
#end
#end

#macro(xrDocumentReference $wrapperTag $id)
