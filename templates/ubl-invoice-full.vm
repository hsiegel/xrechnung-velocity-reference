#macro(xrAdditionalDocumentReference $doc)
#set($xrHasDoc = $xml.has($doc.id) || $xml.has($doc.description) || $xml.has($doc.embedded.content) || $xml.has($doc.embedded.externalUri))
#if($xrHasDoc)
<cac:AdditionalDocumentReference>
  #xrText("cbc:ID" $doc.id)
  #xrText("cbc:DocumentDescription" $doc.description)
  #if($xml.has($doc.embedded.content) || $xml.has($doc.embedded.externalUri))
  <cac:Attachment>
    #if($xml.has($doc.embedded.content))
    <cbc:EmbeddedDocumentBinaryObject#if($xml.has($doc.embedded.mimeCode)) mimeCode="$xml.attr($doc.embedded.mimeCode)"#end#if($xml.has($doc.embedded.filename)) filename="$xml.attr($doc.embedded.filename)"#end>$xml.text($doc.embedded.content)</cbc:EmbeddedDocumentBinaryObject>
    #end
    #if($xml.has($doc.embedded.externalUri))
    <cac:ExternalReference>
      #xrText("cbc:URI" $doc.embedded.externalUri)
    </cac:ExternalReference>
    #end
  </cac:Attachment>
  #end
</cac:AdditionalDocumentReference>
#end
#end

#macro(xrPrice $price $currency)
#set($xrHasPrice = $xml.has($price.netAmount) || $xml.has($price.discount) || $xml.has($price.baseQuantity))
#if($xrHasPrice)
<cac:Price>
  #xrAmount("cbc:PriceAmount" $price.netAmount $currency)
  #xrQuantity("cbc:BaseQuantity" $price.baseQuantity $price.baseQuantityUnitCode)
  #set($xrHasPriceDiscount = $xml.has($price.discount.amount) || $xml.has($price.discount.baseAmount))
  #if($xrHasPriceDiscount)
  <cac:AllowanceCharge>
    <cbc:ChargeIndicator>false</cbc:ChargeIndicator>
    #xrAmount("cbc:Amount" $price.discount.amount $currency)
    #xrAmount("cbc:BaseAmount" $price.discount.baseAmount $currency)
  </cac:AllowanceCharge>
  #end
</cac:Price>
#end
#end

#macro(xrItem $item $tax)
#set($xrHasItem = $xml.has($item.description) || $xml.has($item.name) || $xml.has($item.sellersItemId) || $xml.has($item.buyersItemId) || $xml.has($item.standardId) || $xml.has($item.classifications) || $xml.has($item.originCountryCode) || $xml.has($item.attributes) || $xml.has($tax))
#if($xrHasItem)
<cac:Item>
  #xrText("cbc:Description" $item.description)
  #xrText("cbc:Name" $item.name)
  #if($xml.has($item.buyersItemId))
  <cac:BuyersItemIdentification>
    #xrText("cbc:ID" $item.buyersItemId)
  </cac:BuyersItemIdentification>
  #end
  #if($xml.has($item.sellersItemId))
  <cac:SellersItemIdentification>
    #xrText("cbc:ID" $item.sellersItemId)
  </cac:SellersItemIdentification>
  #end
  #if($xml.has($item.standardId))
  <cac:StandardItemIdentification>
    #xrIdentifier("cbc:ID" $item.standardId $item.standardIdSchemeId)
  </cac:StandardItemIdentification>
  #end
  #if($xml.has($item.originCountryCode))
  <cac:OriginCountry>
    #xrText("cbc:IdentificationCode" $item.originCountryCode)
  </cac:OriginCountry>
  #end
  #if($xml.has($item.classifications))
    #foreach($classification in $item.classifications)
      #if($xml.has($classification.code))
  <cac:CommodityClassification>
    <cbc:ItemClassificationCode#if($xml.has($classification.listId)) listID="$xml.attr($classification.listId)"#end#if($xml.has($classification.listVersionId)) listVersionID="$xml.attr($classification.listVersionId)"#end>$xml.text($classification.code)</cbc:ItemClassificationCode>
  </cac:CommodityClassification>
      #end
    #end
  #end
  #xrTaxCategory("cac:ClassifiedTaxCategory" $tax)
  #if($xml.has($item.attributes))
    #foreach($attribute in $item.attributes)
      #if($xml.has($attribute.name) || $xml.has($attribute.value))
  <cac:AdditionalItemProperty>
    #xrText("cbc:Name" $attribute.name)
    #xrText("cbc:Value" $attribute.value)
  </cac:AdditionalItemProperty>
      #end
    #end
  #end
</cac:Item>
#end
#end

#macro(xrInvoiceLine $line $currency)
#set($xrHasLine = $xml.has($line.id) || $xml.has($line.note) || $xml.has($line.objectReference) || $xml.has($line.quantity) || $xml.has($line.lineExtensionAmount) || $xml.has($line.accountingCost) || $xml.has($line.orderLineReference) || $xml.has($line.period) || $xml.has($line.allowances) || $xml.has($line.charges) || $xml.has($line.item) || $xml.has($line.vat) || $xml.has($line.price))
#if($xrHasLine)
<cac:InvoiceLine>
  #xrText("cbc:ID" $line.id)
  #xrText("cbc:Note" $line.note)
  #xrQuantity("cbc:InvoicedQuantity" $line.quantity $line.quantityUnitCode)
  #xrAmount("cbc:LineExtensionAmount" $line.lineExtensionAmount $currency)
  #xrText("cbc:AccountingCost" $line.accountingCost)
  #xrInvoicePeriod($line.period)
  #if($xml.has($line.orderLineReference))
  <cac:OrderLineReference>
    #xrText("cbc:LineID" $line.orderLineReference)
  </cac:OrderLineReference>
  #end
  #set($xrHasLineObjectReference = $xml.has($line.objectReference.id))
  #if($xrHasLineObjectReference)
  <cac:DocumentReference>
    #xrIdentifier("cbc:ID" $line.objectReference.id $line.objectReference.schemeId)
    <cbc:DocumentTypeCode>130</cbc:DocumentTypeCode>
  </cac:DocumentReference>
  #end
  #if($xml.has($line.allowances))
    #foreach($allowance in $line.allowances)
      #xrAllowanceCharge($allowance "false" $currency)
    #end
  #end
  #if($xml.has($line.charges))
    #foreach($charge in $line.charges)
      #xrAllowanceCharge($charge "true" $currency)
    #end
  #end
  #xrItem($line.item $line.vat)
  #xrPrice($line.price $currency)
</cac:InvoiceLine>
#end
#end
#set($currency = $xr.invoice.documentCurrencyCode)
#set($taxCurrency = $xr.invoice.taxCurrencyCode)
<Invoice
  xmlns="urn:oasis:names:specification:ubl:schema:xsd:Invoice-2"
  xmlns:cac="urn:oasis:names:specification:ubl:schema:xsd:CommonAggregateComponents-2"
  xmlns:cec="urn:oasis:names:specification:ubl:schema:xsd:CommonExtensionComponents-2"
  xmlns:cbc="urn:oasis:names:specification:ubl:schema:xsd:CommonBasicComponents-2">
  ## Header scalars and process identifiers
  #xrText("cbc:CustomizationID" $xr.process.customizationId)
  #xrText("cbc:ProfileID" $xr.process.profileId)
  #xrText("cbc:ID" $xr.invoice.id)
  #xrDate("cbc:IssueDate" $xr.invoice.issueDate)
  #xrDate("cbc:DueDate" $xr.invoice.dueDate)
  #xrText("cbc:InvoiceTypeCode" $xr.invoice.typeCode)
  #if($xml.has($xr.notes))
    #foreach($note in $xr.notes)
      #xrNote("cbc:Note" $note)
    #end
  #end
  #xrDate("cbc:TaxPointDate" $xr.invoice.taxPointDate)
