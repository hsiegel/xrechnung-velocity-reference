#macro(xrText $tag $value)
#if($xml.has($value))
<$tag>$xml.text($value)</$tag>
#end
#end

#macro(xrDate $tag $value)
#if($xml.has($value))
<$tag>$xml.date($value)</$tag>
#end
#end

#macro(xrNumber $tag $value)
#if($xml.has($value))
<$tag>$xml.number($value)</$tag>
#end
#end

#macro(xrAmount $tag $value $currency)
#if($xml.has($value))
<$tag#if($xml.has($currency)) currencyID="$xml.attr($currency)"#end>$xml.amount($value)</$tag>
#end
#end

#macro(xrQuantity $tag $value $unitCode)
#if($xml.has($value))
<$tag#if($xml.has($unitCode)) unitCode="$xml.attr($unitCode)"#end>$xml.number($value)</$tag>
#end
#end

#macro(xrIdentifier $tag $value $schemeId)
#if($xml.has($value))
<$tag#if($xml.has($schemeId)) schemeID="$xml.attr($schemeId)"#end>$xml.text($value)</$tag>
#end
#end

#macro(xrNestedParty $wrapperTag $party)
#set($xrHasParty = $xml.has($party.name) || $xml.has($party.tradeName) || $xml.has($party.endpoint.value) || $xml.has($party.identifier) || $xml.has($party.identifiers) || $xml.has($party.sepaCreditorId) || $xml.has($party.vatIdentifier) || $xml.has($party.taxIdentifier) || $xml.has($party.legalRegistrationId) || $xml.has($party.legalForm) || $xml.has($party.address) || $xml.has($party.contact))
#if($xrHasParty)
<$wrapperTag>
  <cac:Party>
    #xrIdentifier("cbc:EndpointID" $party.endpoint.value $party.endpoint.schemeId)
    #if($xml.has($party.sepaCreditorId))
    <cac:PartyIdentification>
      <cbc:ID schemeID="SEPA">$xml.text($party.sepaCreditorId)</cbc:ID>
    </cac:PartyIdentification>
    #end
    #if($xml.has($party.identifier.value))
    <cac:PartyIdentification>
      #xrIdentifier("cbc:ID" $party.identifier.value $party.identifier.schemeId)
    </cac:PartyIdentification>
    #end
    #if($xml.has($party.identifiers))
      #foreach($identifier in $party.identifiers)
        #if($xml.has($identifier.value))
    <cac:PartyIdentification>
      #xrIdentifier("cbc:ID" $identifier.value $identifier.schemeId)
    </cac:PartyIdentification>
        #end
      #end
    #end
    #if($xml.has($party.tradeName))
    <cac:PartyName>
      #xrText("cbc:Name" $party.tradeName)
    </cac:PartyName>
    #end
    #set($xrAddressLine = "")
    #if($xml.has($party.address.addressLine))
      #set($xrAddressLine = $party.address.addressLine)
    #end
    #set($xrHasAddress = $xml.has($party.address.street) || $xml.has($party.address.additionalStreet) || $xml.has($xrAddressLine) || $xml.has($party.address.city) || $xml.has($party.address.postalCode) || $xml.has($party.address.countrySubdivision) || $xml.has($party.address.countryCode))
    #if($xrHasAddress)
    <cac:PostalAddress>
      #xrText("cbc:StreetName" $party.address.street)
      #xrText("cbc:AdditionalStreetName" $party.address.additionalStreet)
      #xrText("cbc:CityName" $party.address.city)
      #xrText("cbc:PostalZone" $party.address.postalCode)
      #xrText("cbc:CountrySubentity" $party.address.countrySubdivision)
      #if($xml.has($xrAddressLine))
      <cac:AddressLine>
        #xrText("cbc:Line" $xrAddressLine)
      </cac:AddressLine>
      #end
      #if($xml.has($party.address.countryCode))
      <cac:Country>
        #xrText("cbc:IdentificationCode" $party.address.countryCode)
      </cac:Country>
      #end
    </cac:PostalAddress>
    #end
    #if($xml.has($party.vatIdentifier))
    <cac:PartyTaxScheme>
      #xrText("cbc:CompanyID" $party.vatIdentifier)
      <cac:TaxScheme>
        <cbc:ID>VAT</cbc:ID>
      </cac:TaxScheme>
    </cac:PartyTaxScheme>
    #end
    #if($xml.has($party.taxIdentifier))
    <cac:PartyTaxScheme>
      #xrText("cbc:CompanyID" $party.taxIdentifier)
      <cac:TaxScheme>
        <cbc:ID>TAX</cbc:ID>
      </cac:TaxScheme>
    </cac:PartyTaxScheme>
    #end
    #if($xml.has($party.name) || $xml.has($party.legalRegistrationId) || $xml.has($party.legalForm))
    <cac:PartyLegalEntity>
      #xrText("cbc:RegistrationName" $party.name)
      #xrIdentifier("cbc:CompanyID" $party.legalRegistrationId $party.legalRegistrationIdSchemeId)
      #xrText("cbc:CompanyLegalForm" $party.legalForm)
    </cac:PartyLegalEntity>
    #end
    #set($xrHasContact = $xml.has($party.contact.name) || $xml.has($party.contact.phone) || $xml.has($party.contact.email))
    #if($xrHasContact)
    <cac:Contact>
      #xrText("cbc:Name" $party.contact.name)
      #xrText("cbc:Telephone" $party.contact.phone)
      #xrText("cbc:ElectronicMail" $party.contact.email)
    </cac:Contact>
    #end
  </cac:Party>
</$wrapperTag>
#end
#end

#macro(xrPaymentMeans $payment)
#set($xrHasPayment = $xml.has($payment.meansCode) || $xml.has($payment.meansText) || $xml.has($payment.paymentId) || $xml.has($payment.payeeAccounts) || $xml.has($payment.card) || $xml.has($payment.mandate))
#if($xrHasPayment)
<cac:PaymentMeans>
  #if($xml.has($payment.meansCode))
  <cbc:PaymentMeansCode#if($xml.has($payment.meansText)) name="$xml.attr($payment.meansText)"#end>$xml.text($payment.meansCode)</cbc:PaymentMeansCode>
  #end
  #xrText("cbc:PaymentID" $payment.paymentId)
  #if($xml.has($payment.card))
    #if($xml.has($payment.card.primaryAccountNumberId) || $xml.has($payment.card.holderName))
  <cac:CardAccount>
    #xrText("cbc:PrimaryAccountNumberID" $payment.card.primaryAccountNumberId)
    #xrText("cbc:HolderName" $payment.card.holderName)
  </cac:CardAccount>
    #end
  #end
  #if($xml.has($payment.payeeAccounts))
    #foreach($account in $payment.payeeAccounts)
      #if($xml.has($account.id) || $xml.has($account.name) || $xml.has($account.bic))
  <cac:PayeeFinancialAccount>
    #xrText("cbc:ID" $account.id)
    #xrText("cbc:Name" $account.name)
    #if($xml.has($account.bic))
    <cac:FinancialInstitutionBranch>
      #xrText("cbc:ID" $account.bic)
    </cac:FinancialInstitutionBranch>
    #end
  </cac:PayeeFinancialAccount>
      #end
    #end
  #end
  #if($xml.has($payment.mandate))
    #if($xml.has($payment.mandate.id) || $xml.has($payment.mandate.payerAccountId))
  <cac:PaymentMandate>
    #xrText("cbc:ID" $payment.mandate.id)
    #if($xml.has($payment.mandate.payerAccountId))
    <cac:PayerFinancialAccount>
      #xrText("cbc:ID" $payment.mandate.payerAccountId)
    </cac:PayerFinancialAccount>
    #end
  </cac:PaymentMandate>
    #end
  #end
</cac:PaymentMeans>
#end
#end

#macro(xrTaxCategory $wrapperTag $tax)
#set($xrHasTax = $xml.has($tax.categoryCode) || $xml.has($tax.rate) || $xml.has($tax.exemptionReason) || $xml.has($tax.exemptionReasonCode))
#if($xrHasTax)
<$wrapperTag>
  #xrText("cbc:ID" $tax.categoryCode)
  #xrNumber("cbc:Percent" $tax.rate)
  #xrText("cbc:TaxExemptionReason" $tax.exemptionReason)
  #xrText("cbc:TaxExemptionReasonCode" $tax.exemptionReasonCode)
  <cac:TaxScheme>
    <cbc:ID>VAT</cbc:ID>
  </cac:TaxScheme>
</$wrapperTag>
#end
#end

#macro(xrAllowanceCharge $entry $chargeIndicator $currency)
#set($xrHasAllowance = $xml.has($entry.amount) || $xml.has($entry.baseAmount) || $xml.has($entry.percent) || $xml.has($entry.reason) || $xml.has($entry.reasonCode) || $xml.has($entry.tax))
#if($xrHasAllowance)
<cac:AllowanceCharge>
  <cbc:ChargeIndicator>$chargeIndicator</cbc:ChargeIndicator>
  #xrText("cbc:AllowanceChargeReasonCode" $entry.reasonCode)
  #xrText("cbc:AllowanceChargeReason" $entry.reason)
  #xrNumber("cbc:MultiplierFactorNumeric" $entry.percent)
  #xrAmount("cbc:Amount" $entry.amount $currency)
  #xrAmount("cbc:BaseAmount" $entry.baseAmount $currency)
  #xrTaxCategory("cac:TaxCategory" $entry.tax)
</cac:AllowanceCharge>
#end
#end

#macro(xrTaxTotal $documentTaxAmount $accountingTaxAmount $vatBreakdowns $documentCurrency $taxCurrency)
#set($xrHasDocumentTaxTotal = $xml.has($documentTaxAmount) || $xml.has($vatBreakdowns))
#set($xrHasAccountingTaxTotal = $xml.has($accountingTaxAmount) && $xml.has($taxCurrency) && (!$xml.has($documentCurrency) || $taxCurrency != $documentCurrency))
#if($xrHasDocumentTaxTotal)
<cac:TaxTotal>
  #xrAmount("cbc:TaxAmount" $documentTaxAmount $documentCurrency)
  #if($xml.has($vatBreakdowns))
    #foreach($vat in $vatBreakdowns)
      #set($xrHasTaxSubtotal = $xml.has($vat.taxableAmount) || $xml.has($vat.taxAmount) || $xml.has($vat.categoryCode) || $xml.has($vat.rate) || $xml.has($vat.exemptionReason) || $xml.has($vat.exemptionReasonCode))
      #if($xrHasTaxSubtotal)
  <cac:TaxSubtotal>
    #xrAmount("cbc:TaxableAmount" $vat.taxableAmount $documentCurrency)
    #xrAmount("cbc:TaxAmount" $vat.taxAmount $documentCurrency)
    #xrTaxCategory("cac:TaxCategory" $vat)
  </cac:TaxSubtotal>
      #end
    #end
  #end
</cac:TaxTotal>
#end
#if($xrHasAccountingTaxTotal)
<cac:TaxTotal>
  #xrAmount("cbc:TaxAmount" $accountingTaxAmount $taxCurrency)
</cac:TaxTotal>
#end
#end

#macro(xrMonetaryTotal $totals $currency)
#set($xrHasMonetaryTotal = $xml.has($totals.lineExtensionAmount) || $xml.has($totals.allowanceTotalAmount) || $xml.has($totals.chargeTotalAmount) || $xml.has($totals.taxExclusiveAmount) || $xml.has($totals.taxInclusiveAmount) || $xml.has($totals.prepaidAmount) || $xml.has($totals.payableRoundingAmount) || $xml.has($totals.payableAmount))
#if($xrHasMonetaryTotal)
<cac:LegalMonetaryTotal>
  #xrAmount("cbc:LineExtensionAmount" $totals.lineExtensionAmount $currency)
  #xrAmount("cbc:TaxExclusiveAmount" $totals.taxExclusiveAmount $currency)
  #xrAmount("cbc:TaxInclusiveAmount" $totals.taxInclusiveAmount $currency)
  #xrAmount("cbc:AllowanceTotalAmount" $totals.allowanceTotalAmount $currency)
  #xrAmount("cbc:ChargeTotalAmount" $totals.chargeTotalAmount $currency)
  #xrAmount("cbc:PrepaidAmount" $totals.prepaidAmount $currency)
  #xrAmount("cbc:PayableRoundingAmount" $totals.payableRoundingAmount $currency)
  #xrAmount("cbc:PayableAmount" $totals.payableAmount $currency)
</cac:LegalMonetaryTotal>
#end
#end

#macro(xrInvoiceLine $line $currency)
#set($xrHasLine = $xml.has($line.id) || $xml.has($line.note) || $xml.has($line.objectReference) || $xml.has($line.quantity) || $xml.has($line.lineExtensionAmount) || $xml.has($line.accountingCost) || $xml.has($line.orderLineReference) || $xml.has($line.period) || $xml.has($line.allowances) || $xml.has($line.charges) || $xml.has($line.item) || $xml.has($line.vat) || $xml.has($line.price))
#if($xrHasLine)
<cac:InvoiceLine>
  #xrText("cbc:ID" $line.id)
  #xrText("cbc:Note" $line.note)
  #xrQuantity("cbc:InvoicedQuantity" $line.quantity $line.quantityUnitCode)
  #xrAmount("cbc:LineExtensionAmount" $line.lineExtensionAmount $currency)
  #xrText("cbc:AccountingCost" $line.accountingCost)
  #set($xrHasPeriod = $xml.has($line.period.startDate) || $xml.has($line.period.endDate) || $xml.has($line.period.descriptionCode))
  #if($xrHasPeriod)
  <cac:InvoicePeriod>
    #xrDate("cbc:StartDate" $line.period.startDate)
    #xrDate("cbc:EndDate" $line.period.endDate)
    #xrText("cbc:DescriptionCode" $line.period.descriptionCode)
  </cac:InvoicePeriod>
  #end
  #if($xml.has($line.orderLineReference))
  <cac:OrderLineReference>
    #xrText("cbc:LineID" $line.orderLineReference)
  </cac:OrderLineReference>
  #end
  #set($xrHasLineObjectReference = $xml.has($line.objectReference.id))
  #if($xrHasLineObjectReference)
  <cac:DocumentReference>
    #xrIdentifier("cbc:ID" $line.objectReference.id $line.objectReference.schemeId)
    <cbc:DocumentTypeCode>130</cbc:DocumentTypeCode>
  </cac:DocumentReference>
  #end
  #if($xml.has($line.allowances))
    #foreach($allowance in $line.allowances)
      #xrAllowanceCharge($allowance "false" $currency)
    #end
  #end
  #if($xml.has($line.charges))
    #foreach($charge in $line.charges)
      #xrAllowanceCharge($charge "true" $currency)
    #end
  #end
  #set($xrHasItem = $xml.has($line.item.description) || $xml.has($line.item.name) || $xml.has($line.item.sellersItemId) || $xml.has($line.item.buyersItemId) || $xml.has($line.item.standardId) || $xml.has($line.item.classifications) || $xml.has($line.item.originCountryCode) || $xml.has($line.item.attributes) || $xml.has($line.vat))
  #if($xrHasItem)
  <cac:Item>
    #xrText("cbc:Description" $line.item.description)
    #xrText("cbc:Name" $line.item.name)
    #if($xml.has($line.item.buyersItemId))
    <cac:BuyersItemIdentification>
      #xrText("cbc:ID" $line.item.buyersItemId)
    </cac:BuyersItemIdentification>
    #end
    #if($xml.has($line.item.sellersItemId))
    <cac:SellersItemIdentification>
      #xrText("cbc:ID" $line.item.sellersItemId)
    </cac:SellersItemIdentification>
    #end
    #if($xml.has($line.item.standardId))
    <cac:StandardItemIdentification>
      #xrIdentifier("cbc:ID" $line.item.standardId $line.item.standardIdSchemeId)
    </cac:StandardItemIdentification>
    #end
    #if($xml.has($line.item.originCountryCode))
    <cac:OriginCountry>
      #xrText("cbc:IdentificationCode" $line.item.originCountryCode)
    </cac:OriginCountry>
    #end
    #if($xml.has($line.item.classifications))
      #foreach($classification in $line.item.classifications)
        #if($xml.has($classification.code))
    <cac:CommodityClassification>
      <cbc:ItemClassificationCode#if($xml.has($classification.listId)) listID="$xml.attr($classification.listId)"#end#if($xml.has($classification.listVersionId)) listVersionID="$xml.attr($classification.listVersionId)"#end>$xml.text($classification.code)</cbc:ItemClassificationCode>
    </cac:CommodityClassification>
        #end
      #end
    #end
    #xrTaxCategory("cac:ClassifiedTaxCategory" $line.vat)
    #if($xml.has($line.item.attributes))
      #foreach($attribute in $line.item.attributes)
        #if($xml.has($attribute.name) || $xml.has($attribute.value))
    <cac:AdditionalItemProperty>
      #xrText("cbc:Name" $attribute.name)
      #xrText("cbc:Value" $attribute.value)
    </cac:AdditionalItemProperty>
        #end
      #end
    #end
  </cac:Item>
  #end
  #set($xrHasPrice = $xml.has($line.price.netAmount) || $xml.has($line.price.discount) || $xml.has($line.price.baseQuantity))
  #if($xrHasPrice)
  <cac:Price>
    #xrAmount("cbc:PriceAmount" $line.price.netAmount $currency)
    #xrQuantity("cbc:BaseQuantity" $line.price.baseQuantity $line.price.baseQuantityUnitCode)
    #set($xrHasPriceDiscount = $xml.has($line.price.discount.amount) || $xml.has($line.price.discount.baseAmount))
    #if($xrHasPriceDiscount)
    <cac:AllowanceCharge>
      <cbc:ChargeIndicator>false</cbc:ChargeIndicator>
      #xrAmount("cbc:Amount" $line.price.discount.amount $currency)
      #xrAmount("cbc:BaseAmount" $line.price.discount.baseAmount $currency)
    </cac:AllowanceCharge>
    #end
  </cac:Price>
  #end
</cac:InvoiceLine>
#end
#end
#set($currency = $xr.invoice.documentCurrencyCode)
<Invoice
  xmlns="urn:oasis:names:specification:ubl:schema:xsd:Invoice-2"
  xmlns:cac="urn:oasis:names:specification:ubl:schema:xsd:CommonAggregateComponents-2"
  xmlns:cec="urn:oasis:names:specification:ubl:schema:xsd:CommonExtensionComponents-2"
  xmlns:cbc="urn:oasis:names:specification:ubl:schema:xsd:CommonBasicComponents-2">
  ## BG-2 process control
  #xrText("cbc:CustomizationID" $xr.process.customizationId)
  #xrText("cbc:ProfileID" $xr.process.profileId)

  ## Invoice header core
  #xrText("cbc:ID" $xr.invoice.id)
  #xrDate("cbc:IssueDate" $xr.invoice.issueDate)
  #xrDate("cbc:DueDate" $xr.invoice.dueDate)
  #xrText("cbc:InvoiceTypeCode" $xr.invoice.typeCode)
  #xrText("cbc:DocumentCurrencyCode" $xr.invoice.documentCurrencyCode)
  #xrText("cbc:BuyerReference" $xr.invoice.buyerReference)

  ## BG-4 seller
  #xrNestedParty("cac:AccountingSupplierParty" $xr.seller)

  ## BG-7 buyer
  #xrNestedParty("cac:AccountingCustomerParty" $xr.buyer)

  ## BG-16 payment instructions
  #xrPaymentMeans($xr.payment)

  ## Synthetic UBL wrapper for BT-110 and BG-23
  #xrTaxTotal($xr.totals.taxAmountInDocumentCurrency "" $xr.vatBreakdowns $currency "")

  ## BG-22 document totals
  #xrMonetaryTotal($xr.totals $currency)

  ## BG-25 invoice lines
  #if($xml.has($xr.lines))
    #foreach($line in $xr.lines)
      #xrInvoiceLine($line $currency)
    #end
  #end
</Invoice>
